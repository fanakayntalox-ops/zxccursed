local function getEmotesForPage(page)
    if page == 1 then
        return EmoteSystem.Page1
    elseif page == 2 then
        return EmoteSystem.Page2
    elseif page == 3 then
        return EmoteSystem.Page3
    end
    return EmoteSystem.Page1
end

local function findEmotionPaths()
    local paths = {}
    for name, path in pairs(EmoteSystem.AnimationPaths) do
        if type(path) == "string" then
            if path:find("rbxassetid://") then
                local anim = Instance.new("Animation")
                anim.AnimationId = path
                anim.Name = name
                paths[name] = anim
            else
                local success, obj = pcall(function()
                    return EmoteSystem.GetAnimation(path)
                end)
                if success and obj then
                    paths[name] = obj
                end
            end
        end
    end
    return paths
end


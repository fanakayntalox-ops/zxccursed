local function playEmote(emoteName)
    if not EmoteSystem.Enabled or not emoteName or emoteName == "" then return false end
    
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return false end
    
    local animation = EmoteSystem.FoundEmotions[emoteName]
    if not animation then return false end
    
    local animator = humanoid:FindFirstChild("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = humanoid
    end
    
    local currentTime = tick()
    if currentTime - EmoteSystem.LastEmotePlayed < EmoteSystem.EmoteCooldown then
        return false
    end
    
    if EmoteSystem.CurrentAnimationTrack and EmoteSystem.IsEmotePlaying then
        EmoteSystem.CurrentAnimationTrack:Stop()
    end
    
    local animInstance
    if animation:IsA("Animation") then
        animInstance = animation
    elseif animation:IsA("StringValue") or animation:IsA("ObjectValue") then
        local animId = animation.Value
        if type(animId) == "string" then
            animInstance = Instance.new("Animation")
            animInstance.AnimationId = animId
            animInstance.Name = emoteName
        end
    end
    
    if not animInstance then return false end
    
    local success, track = pcall(function()
        return animator:LoadAnimation(animInstance)
    end)
    
    if success and track then
        track.Priority = Enum.AnimationPriority.Action4
        track:Play()
        EmoteSystem.CurrentAnimationTrack = track
        EmoteSystem.IsEmotePlaying = true
        EmoteSystem.LastEmotePlayed = currentTime
        return true
    end
    return false
end

local function stopCurrentEmote()
    if EmoteSystem.CurrentAnimationTrack and EmoteSystem.IsEmotePlaying then
        EmoteSystem.CurrentAnimationTrack:Stop()
        EmoteSystem.CurrentAnimationTrack = nil
        EmoteSystem.IsEmotePlaying = false
        return true
    end
    return false
end

local function updateWheelPage()
    if not EmoteSystem.WheelFrame or not EmoteSystem.WheelFrame.Visible then return end
    
    local currentEmotes = getEmotesForPage(EmoteSystem.CurrentPage)
    
    for i, circleData in ipairs(EmoteSystem.Circles) do
        if i <= #currentEmotes then
            local name = currentEmotes[i]
            local displayName = name
            
            if string.len(name) > 10 then
                if name == "Strange Movement" then displayName = "Strange"
                elseif name == "Orange Justice" then displayName = "Orange"
                elseif name == "Ride the Pony" then displayName = "Pony"
                elseif name == "Go Cat Go" then displayName = "Cat"
                elseif name == "Default Dance" then displayName = "Default"
                elseif name == "Electro Shuffle" then displayName = "Electro"
                elseif name == "Russian Dance" then displayName = "Russian"
                elseif name == "Party Rocker" then displayName = "Party"
                elseif name == "Jabba Switchway" then displayName = "Jabba"
                elseif name == "Zero Two" then displayName = "Zero2"
                elseif name == "Ishowspeed" then displayName = "Speed"
                elseif name == "Zelenskiy" then displayName = "Zelenskiy"
                elseif name == "Billy Bounce" then displayName = "Billy"
                elseif name == "Gangnam Style" then displayName = "Gangnam"
                end
            end
            
            circleData.frame.Visible = true
            circleData.label.Text = displayName
            circleData.name = name
        else
            circleData.frame.Visible = false
        end
    end
    
    if EmoteSystem.PageIndicator then
        EmoteSystem.PageIndicator.Text = "Page " .. EmoteSystem.CurrentPage .. "/3"
    end
end

local function checkHover()
    if not EmoteSystem.EmoteWheelActive or not EmoteSystem.WheelFrame or not EmoteSystem.WheelFrame.Visible then return end
    
    local mouse = LocalPlayer:GetMouse()
    local mousePos = Vector2.new(mouse.X, mouse.Y)
    
    local wheelCenter = Vector2.new(
        EmoteSystem.WheelFrame.AbsolutePosition.X + EmoteSystem.WheelFrame.AbsoluteSize.X / 2,
        EmoteSystem.WheelFrame.AbsolutePosition.Y + EmoteSystem.WheelFrame.AbsoluteSize.Y / 2
    )
    
    local currentTime = tick()
    
    for i, circleData in ipairs(EmoteSystem.Circles) do
        if circleData.frame.Visible then
            local circlePos = Vector2.new(
                wheelCenter.X + circleData.x,
                wheelCenter.Y + circleData.y
            )
            
            local distance = (mousePos - circlePos).Magnitude
            
            if distance <= 35 then
                circleData.frame.BackgroundColor3 = EmoteSystem.Colors.deepPurple
                circleData.frame.BackgroundTransparency = 0.2
                circleData.label.TextColor3 = EmoteSystem.Colors.white
                circleData.label.TextTransparency = 0
                circleData.stroke.Color = EmoteSystem.Colors.lightPurple
                circleData.stroke.Thickness = 3
                
                if currentTime - circleData.lastEmoteTime >= EmoteSystem.EmoteCooldown then
                    playEmote(circleData.name)
                    circleData.lastEmoteTime = currentTime
                end
            else
                circleData.frame.BackgroundColor3 = EmoteSystem.Colors.mediumBlue
                circleData.frame.BackgroundTransparency = 0.3
                circleData.label.TextColor3 = EmoteSystem.Colors.lightPurple
                circleData.label.TextTransparency = 0.3
                circleData.stroke.Color = EmoteSystem.Colors.lightPurple
                circleData.stroke.Thickness = 2
            end
        end
    end
end

local function showWheel()
    if not EmoteSystem.Enabled then return end
    
    stopCurrentEmote()
    EmoteSystem.EmoteWheelActive = true
    if EmoteSystem.WheelFrame then
        EmoteSystem.CurrentPage = 1
        updateWheelPage()
        EmoteSystem.WheelFrame.Visible = true
    end
    
    UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    UserInputService.MouseIconEnabled = true
end

local function hideWheel()
    EmoteSystem.EmoteWheelActive = false
    if EmoteSystem.WheelFrame then
        EmoteSystem.WheelFrame.Visible = false
    end
    
    UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    UserInputService.MouseIconEnabled = false
end

local function switchPage(direction)
    if not EmoteSystem.EmoteWheelActive then return end
    
    local currentTime = tick()
    if currentTime - EmoteSystem.LastPageSwitch < EmoteSystem.PageSwitchCooldown then
        return
    end
    
    local newPage = EmoteSystem.CurrentPage + direction
    
    if newPage < 1 then newPage = 1 end
    if newPage > 3 then newPage = 3 end
    
    if newPage == EmoteSystem.CurrentPage then
        return
    end
    
    EmoteSystem.CurrentPage = newPage
    updateWheelPage()
    EmoteSystem.LastPageSwitch = currentTime
end

local function updateEmoteSystem()
    if EmoteSystem.Enabled then
        if not EmoteSystem.WheelGUI then
            createEmoteWheel()
        end
    else
        if EmoteSystem.WheelGUI then
            EmoteSystem.WheelGUI:Destroy()
            EmoteSystem.WheelGUI = nil
            EmoteSystem.WheelFrame = nil
            EmoteSystem.Circles = {}
        end
    end
end

task.spawn(function()
    task.wait(1)
    createEmoteWheel()
    
    ContextActionService:BindAction("EmoteWheel", function(_, state)
        if state == Enum.UserInputState.Begin then
            showWheel()
        elseif state == Enum.UserInputState.End then
            hideWheel()
        end
    end, false, Enum.KeyCode[EmoteSystem.WheelKey])
    
    ContextActionService:BindAction("NextPage", function(_, state)
        if state == Enum.UserInputState.Begin then
            switchPage(1)
        end
    end, false, Enum.KeyCode[EmoteSystem.NextPageKey])
    
    ContextActionService:BindAction("PrevPage", function(_, state)
        if state == Enum.UserInputState.Begin then
            switchPage(-1)
        end
    end, false, Enum.KeyCode[EmoteSystem.PrevPageKey])
end)


-- ==================== NO COLLISION ====================

local NoCollision = {
    Enabled = _G.Settings.NoCollision_Enabled,
    Key = _G.Settings.NoCollision_Key,
    Active = false,
    IsHolding = false,
    Radius = 30,
    AffectedParts = {},
    OriginalStates = {},
    ScanComplete = false,
    CachedParts = {}
}

local function cacheAllParts()
    local parts = {}
    local count = 0
    
    for _, descendant in pairs(Workspace:GetDescendants()) do
        if descendant:IsA("BasePart") and descendant.CanCollide then
            local ignore = false
            if descendant.Parent then
                local player = Players:GetPlayerFromCharacter(descendant.Parent)
                if player then
                    ignore = true
                end
            end
            
            if not ignore then
                table.insert(parts, descendant)
                count = count + 1
            end
        end
    end
    
    NoCollision.CachedParts = parts
    NoCollision.ScanComplete = true
end

local function getPartsInRadius(centerPos, radius)
    local nearbyParts = {}
    
    for _, part in ipairs(NoCollision.CachedParts) do
        if part and part.Parent then
            local dist = (part.Position - centerPos).Magnitude
            if dist <= radius then
                table.insert(nearbyParts, part)
            end
        end
    end
    
    return nearbyParts
end

local function enablePhantomMode()
    if not NoCollision.Enabled then 
        return 
    end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    if NoCollision.Active then
        return
    end
    
    if not NoCollision.ScanComplete then
        cacheAllParts()
    end
    
    NoCollision.Active = true
    NoCollision.IsHolding = true
    NoCollision.AffectedParts = {}
    NoCollision.OriginalStates = {}
    
    local centerPos = hrp.Position
    local nearbyParts = getPartsInRadius(centerPos, NoCollision.Radius)
    local affectedCount = 0
    
    for _, part in ipairs(nearbyParts) do
        if part and part.Parent then
            if NoCollision.OriginalStates[part] == nil then
                NoCollision.OriginalStates[part] = part.CanCollide
            end
            
            if part.CanCollide then
                part.CanCollide = false
                table.insert(NoCollision.AffectedParts, part)
                affectedCount = affectedCount + 1
                
                if part.Parent and part.Parent:IsA("Model") then
                    for _, child in pairs(part.Parent:GetDescendants()) do
                        if child:IsA("BasePart") and child ~= part and child.CanCollide then
                            if NoCollision.OriginalStates[child] == nil then
                                NoCollision.OriginalStates[child] = child.CanCollide
                            end
                            child.CanCollide = false
                            table.insert(NoCollision.AffectedParts, child)
                            affectedCount = affectedCount + 1
                        end
                    end
                end
            end
        end
    end
end

local function disablePhantomMode()
    if not NoCollision.Active then
        return
    end
    
    NoCollision.Active = false
    NoCollision.IsHolding = false
    
    for part, originalState in pairs(NoCollision.OriginalStates) do
        if part and part.Parent then
            part.CanCollide = originalState
        end
    end
    
    NoCollision.AffectedParts = {}
    NoCollision.OriginalStates = {}
end

local function updateNoCollision()
    if NoCollision.Enabled then
        if not NoCollision.ScanComplete then
            task.spawn(cacheAllParts)
        end
    else
        if NoCollision.Active then
            disablePhantomMode()
        end
        NoCollision.CachedParts = {}
        NoCollision.ScanComplete = false
    end
end


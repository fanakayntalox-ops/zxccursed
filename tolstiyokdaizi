local function updateSpeedHack()
    if SpeedHack.Connection then
        SpeedHack.Connection:Disconnect()
        SpeedHack.Connection = nil
    end
    
    if not SpeedHack.Enabled then
        SpeedHack.Active = false
        updateShiftLock()
        return
    end
    
    if SpeedHack.Mode == "Always On" then
        SpeedHack.Active = true
        SpeedHack.Connection = startMicroTeleport(SpeedHack.Speed, SpeedHack)
        updateShiftLock()
    elseif SpeedHack.Mode == "Toggle" then
        if SpeedHack.Active then
            SpeedHack.Connection = startMicroTeleport(SpeedHack.Speed, SpeedHack)
            updateShiftLock()
        else
            updateShiftLock()
        end
    elseif SpeedHack.Mode == "Hold" then
        if SpeedHack.Active then
            SpeedHack.Connection = startMicroTeleport(SpeedHack.Speed, SpeedHack)
            updateShiftLock()
        else
            updateShiftLock()
        end
    end
end

local function handleSpeedHackKey()
    if not SpeedHack.Enabled then return end
    
    if SpeedHack.Mode == "Toggle" then
        SpeedHack.Active = not SpeedHack.Active
        updateSpeedHack()
    elseif SpeedHack.Mode == "Hold" then
        SpeedHack.Active = true
        updateSpeedHack()
    end
end

local function handleSpeedHackKeyRelease()
    if not SpeedHack.Enabled then return end
    
    if SpeedHack.Mode == "Hold" then
        SpeedHack.Active = false
        if SpeedHack.Connection then
            SpeedHack.Connection:Disconnect()
            SpeedHack.Connection = nil
        end
        updateShiftLock()
    end
end


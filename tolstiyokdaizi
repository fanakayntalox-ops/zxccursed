local function findSkillCheckEvent()
    local RemoteEvents = ReplicatedStorage:FindFirstChild("RemoteEvents")
    if RemoteEvents then
        local skillCheckResult = RemoteEvents:FindFirstChild("SkillCheckResult")
        if skillCheckResult then
            return skillCheckResult
        end
    end
    
    local skillCheckResult = ReplicatedStorage:FindFirstChild("SkillCheckResult", true)
    if skillCheckResult then

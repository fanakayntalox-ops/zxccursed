local function monitorSpeed()
    while OldAnims.Enabled do
        task.wait(2)
        
        local targetAssets = ReplicatedStorage:FindFirstChild("Game_Assets")
        if targetAssets then
            local targetAnimations = targetAssets:FindFirstChild("Animations")
            if targetAnimations then
                local targetMovement = targetAnimations:FindFirstChild("Movement")
                if targetMovement then
                    local animFolder = targetMovement:FindFirstChild("Survivor")
                    if animFolder then
                        local injuredRun = animFolder:FindFirstChild("Default_Injured_Run")
                        if injuredRun and injuredRun:IsA("Animation") then
                            local speed = injuredRun:GetAttribute("Speed")
                            if speed ~= 0.39 then
                                injuredRun:SetAttribute("Speed", 0.39)
                            end
                        end
                        
                        local medkitRun = animFolder:FindFirstChild("Medkit_Injured_Run")
                        if medkitRun and medkitRun:IsA("Animation") then
                            local speed = medkitRun:GetAttribute("Speed")
                            if speed ~= 0.39 then
                                medkitRun:SetAttribute("Speed", 0.39)
                            end
                        end
                    end
                end
            end
        end
    end
end

local function waitForFolders()
    local attempts = 0
    while attempts < 30 do
        local targetAssets = ReplicatedStorage:FindFirstChild("Game_Assets")
        if targetAssets then
            return true
        end
        task.wait(1)
        attempts = attempts + 1
    end
    return false
end


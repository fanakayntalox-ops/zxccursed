local function disableObjectESP(objectName)
    if not objectESPData[objectName] then return end

    if objectESPConnections[objectName] then
        objectESPConnections[objectName]:Disconnect()
        objectESPConnections[objectName] = nil
    end

    for _, data in pairs(objectESPData[objectName]) do
        if data.billboard then
            data.billboard:Destroy()
        end
    end
    
    if objectHighlights[objectName] then
        for _, hl in pairs(objectHighlights[objectName]) do
            if hl then
                hl:Destroy()
            end
        end
        objectHighlights[objectName] = nil
    end
    
    objectESPData[objectName] = nil
end

local function updateObjectESP()
    if not ObjectESP.Enabled then
        for objectType, _ in pairs(objectESPData) do
            disableObjectESP(objectType)
        end
        return
    end
    
    local currentTime = tick()
    if currentTime - ObjectESP.LastUpdate < ObjectESP.UpdateInterval then
        return
    end
    ObjectESP.LastUpdate = currentTime
    
    local objectTypes = {
        Hatch = {name = "Hatch", label = "Hatch", color = ObjectESP.Colors.Hatch},
        ExitGate = {name = "ExitGate", label = "Exit Gate", color = ObjectESP.Colors.ExitGate},
        Generator = {name = "Generator", label = "Generator", color = ObjectESP.Colors.Generator},
        Window = {name = "Window", label = "Window", color = ObjectESP.Colors.Window},
        Hook = {name = "Hook", label = "Hook", color = ObjectESP.Colors.Hook},
        Pallet = {name = "Pallet", label = "Pallet", color = ObjectESP.Colors.Pallet},
        Trap = {name = "Trap", label = "Trap", color = ObjectESP.Colors.Trap},
        Totem = {name = "Totem", label = "Totem", color = ObjectESP.Colors.Totem},
        Chest = {name = "Chest", label = "Chest", color = ObjectESP.Colors.Chest}
    }
    
    for typeName, settings in pairs(objectTypes) do
        if ObjectESP[typeName] then
            if not objectESPData[settings.name] then
                enableObjectESP(settings.name, settings.label, settings.color)
            end
            
            for _, data in pairs(objectESPData[settings.name] or {}) do
                if data.billboard and data.object and data.object.Parent then
                    local dist = getDistance(data.object)
                    local fadeAlpha = math.clamp(1 - (dist / ObjectESP.MaxDistance), 0, 1)
                    
                    data.billboard.Enabled = dist <= ObjectESP.MaxDistance
                    
                    for _, child in pairs(data.billboard:GetChildren()) do
                        if child:IsA("TextLabel") then
                            child.TextTransparency = 1 - fadeAlpha
                            child.TextStrokeTransparency = 1 - fadeAlpha
                        end
                    end
                    
                    local distanceLabel = data.billboard:FindFirstChild("DistanceLabel")
                    if distanceLabel then
                        if ObjectESP.ShowDistance then
                            distanceLabel.Text = string.format("[ %.1f m ]", dist)
                            
                            local t = math.clamp(1 - (dist / 50), 0, 1)
                            local white = Color3.new(1, 1, 1)
                            local green = Color3.new(0, 1, 0)
                            local distColor = white:Lerp(green, t)
                            distanceLabel.TextColor3 = distColor
                        else
                            distanceLabel.Text = ""
                        end
                    end
                    
                    if ObjectESP.Highlights then
                        for _, hl in pairs(objectHighlights[settings.name] or {}) do
                            if hl.Adornee == data.object then
                                hl.FillTransparency = 0.5 - (fadeAlpha * 0.3)
                                hl.OutlineTransparency = 0.2 - (fadeAlpha * 0.2)
                                hl.Enabled = dist <= ObjectESP.MaxDistance
                            end
                        end
                    end
                end
            end
        else
            if objectESPData[settings.name] then
                disableObjectESP(settings.name)
            end
        end
    end
end


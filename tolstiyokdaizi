local Moonwalk = {
    Enabled = _G.Settings.Moonwalk_Enabled,
    Key = _G.Settings.Moonwalk_Key,
    WIGGLE_AMOUNT = 0.23,
    WIGGLE_SPEED = 32,
    MOONWALK_SPEED_MULTIPLIER = 1.0,
    Active = false,
    MoonwalkType = _G.Settings.Moonwalk_Type,
    OriginalWalkSpeed = 16,
    OriginalAutoRotate = true,
    WiggleAngle = 0,
    LastMoveDirection = Vector3.new(0, 0, 0)
}

local function ToggleMoonwalk()
    if not Moonwalk.Enabled then return end
    
    Moonwalk.Active = not Moonwalk.Active
    
    if Moonwalk.Active then
        local Character = LocalPlayer.Character
        if Character and Character:FindFirstChildOfClass("Humanoid") then
            Moonwalk.OriginalWalkSpeed = Character.Humanoid.WalkSpeed
            Moonwalk.OriginalAutoRotate = Character.Humanoid.AutoRotate 
            Character.Humanoid.WalkSpeed = Moonwalk.OriginalWalkSpeed * Moonwalk.MOONWALK_SPEED_MULTIPLIER
            Character.Humanoid.AutoRotate = false
        end
    else
        local Character = LocalPlayer.Character
        if Character and Character:FindFirstChildOfClass("Humanoid") then
            Character.Humanoid.WalkSpeed = Moonwalk.OriginalWalkSpeed
            Character.Humanoid.AutoRotate = Moonwalk.OriginalAutoRotate
        end
    end
end

RunService.Heartbeat:Connect(function(dt)
    if not Moonwalk.Active then return end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local humanoid = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local camera = workspace.CurrentCamera
    if camera then
        local moveDirection = humanoid.MoveDirection
        if moveDirection.Magnitude > 0.1 then
            Moonwalk.LastMoveDirection = moveDirection
            
            Moonwalk.WiggleAngle = Moonwalk.WiggleAngle + dt * Moonwalk.WIGGLE_SPEED
            local wiggleOffset = math.sin(Moonwalk.WiggleAngle) * Moonwalk.WIGGLE_AMOUNT
            local cameraLook = camera.CFrame.LookVector
            local targetAngle
            
            if Moonwalk.MoonwalkType == "Backward" then
                targetAngle = math.atan2(cameraLook.X, cameraLook.Z) + math.pi + wiggleOffset
                humanoid:Move(-cameraLook)
            elseif Moonwalk.MoonwalkType == "Forward" then
                targetAngle = math.atan2(cameraLook.X, cameraLook.Z) + wiggleOffset
                humanoid:Move(cameraLook)
            elseif Moonwalk.MoonwalkType == "Left Side" then
                targetAngle = math.atan2(cameraLook.X, cameraLook.Z) + math.pi / 2 + wiggleOffset
                local sideLook = Vector3.new(-cameraLook.Z, 0, cameraLook.X).Unit
                humanoid:Move(sideLook)
            elseif Moonwalk.MoonwalkType == "Right Side" then
                targetAngle = math.atan2(cameraLook.X, cameraLook.Z) - math.pi / 2 + wiggleOffset
                local sideLook = Vector3.new(cameraLook.Z, 0, -cameraLook.X).Unit
                humanoid:Move(sideLook)
            end
            
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(
                LocalPlayer.Character.HumanoidRootPart.Position
            ) * CFrame.Angles(0, targetAngle, 0)
        else
            if Moonwalk.LastMoveDirection.Magnitude > 0 then
                local targetLook = Vector3.new(Moonwalk.LastMoveDirection.X, 0, Moonwalk.LastMoveDirection.Z).Unit
                if targetLook.Magnitude > 0.1 then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(
                        LocalPlayer.Character.HumanoidRootPart.Position,
                        LocalPlayer.Character.HumanoidRootPart.Position + targetLook
                    )
                end
            end
        end
    end
end)


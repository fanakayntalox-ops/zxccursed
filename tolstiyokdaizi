local function getScreenPosition(part)
    if not part then return nil end
    local success, result = pcall(function()
        local pos, onScreen = Camera:WorldToViewportPoint(part.Position)
        if onScreen then
            return Vector2.new(pos.X, pos.Y)
        end
        return nil
    end)
    if success and result then
        return result
    end
    return nil
end

local function getPlayerHealthState(player)
    if player == LocalPlayer then
        local healthState = findHealthState()
        if healthState then
            return healthState.Value
        end
        return 2
    end
    
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        local scripts = backpack:FindFirstChild("Scripts") or backpack:FindFirstChild("scripts")
        if scripts then
            local values = scripts:FindFirstChild("values") or scripts:FindFirstChild("Values")
            if values then
                local healthState = values:FindFirstChild("HealthState")
                if healthState then
                    return healthState.Value
                end
            end
        end
    end
    
    return 2
end


local function findHealingEvent()
    local remoteEvents = game:GetService("ReplicatedStorage"):FindFirstChild("RemoteEvents")
    if remoteEvents then
        local clientToServer = remoteEvents:FindFirstChild("ClientToServer")
        if clientToServer then
            local healingEvent = clientToServer:FindFirstChild("HealingEvent")
            if healingEvent then
                return healingEvent
            end
        end
    end
    return nil
end

local function findHealingAnimation()
    local path = game:GetService("Players").LocalPlayer.Backpack.Scripts.GlobalSurvivor.Action["Healing Aid"].Animation
    if path then
        return path
    end
    
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        local scripts = backpack:FindFirstChild("Scripts") or backpack:FindFirstChild("scripts")
        if scripts then
            local globalSurvivor = scripts:FindFirstChild("GlobalSurvivor")
            if globalSurvivor then
                local action = globalSurvivor:FindFirstChild("Action")
                if action then
                    local healingAid = action:FindFirstChild("Healing Aid")
                    if healingAid then
                        local animation = healingAid:FindFirstChild("Animation")
                        if animation then
                            return animation
                        end
                    end
                end
            end
        end
    end
    
    return nil
end

local function playHealingAnimation()
    if not SelfHeal.HealingAnimation then
        SelfHeal.HealingAnimation = findHealingAnimation()
    end
    
    if not SelfHeal.HealingAnimation then
        return false
    end
    
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return false end
    
    local animator = humanoid:FindFirstChild("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = humanoid
    end
    
    local animInstance
    if SelfHeal.HealingAnimation:IsA("Animation") then
        animInstance = SelfHeal.HealingAnimation
    elseif SelfHeal.HealingAnimation:IsA("StringValue") or SelfHeal.HealingAnimation:IsA("ObjectValue") then
        local animId = SelfHeal.HealingAnimation.Value
        if type(animId) == "string" then
            animInstance = Instance.new("Animation")
            animInstance.AnimationId = animId
            animInstance.Name = "HealingAnimation"
        end
    end
    
    if not animInstance then return false end
    
    local success, track = pcall(function()
        return animator:LoadAnimation(animInstance)
    end)
    
    if success and track then
        track.Priority = Enum.AnimationPriority.Action4
        track:Play()
        SelfHeal.AnimationTrack = track
        return true
    end
    
    return false
end

local function stopHealingAnimation()
    if SelfHeal.AnimationTrack then
        SelfHeal.AnimationTrack:Stop()
        SelfHeal.AnimationTrack = nil
    end
end

local function stopHealing()
    if not SelfHeal.Active then return end
    
    if SelfHeal.HealingEvent then
        pcall(function()
            SelfHeal.HealingEvent:FireServer(LocalPlayer.Name, "Stop")
        end)
    end
    
    if SelfHeal.Connection then
        SelfHeal.Connection:Disconnect()
        SelfHeal.Connection = nil
    end
    
    stopHealingAnimation()
    
    SelfHeal.Active = false
end

local function startHealing()
    if SelfHeal.Active then 
        stopHealing()
        return
    end
    
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") then
        return
    end
    
    SelfHeal.HealingEvent = findHealingEvent()
    if not SelfHeal.HealingEvent then
        return
    end
    
    SelfHeal.Active = true
    SelfHeal.LastPosition = LocalPlayer.Character.HumanoidRootPart.Position
    
    playHealingAnimation()
    
    pcall(function()
        SelfHeal.HealingEvent:FireServer(LocalPlayer.Name, "Start", {
            SelfHealing = true,
            RestrictValues = true,
            IsMending = false,
            SumKeys = {"SelfCare"}
        })
    end)
    
    SelfHeal.Connection = RunService.Heartbeat:Connect(function()
        pcall(function()
            if not SelfHeal.Active or not LocalPlayer.Character then
                return
            end
            
            local currentPosition = LocalPlayer.Character.HumanoidRootPart.Position
            local distance = (currentPosition - SelfHeal.LastPosition).Magnitude
            
            if distance > 1 then
                stopHealing()
            else
                SelfHeal.LastPosition = currentPosition
            end
        end)
    end)
end

local function toggleSelfHeal()
    if not SelfHeal.Enabled or CurrentRole ~= "Survivor" then return end
    startHealing()
end

local function updateSelfHeal()
    if SelfHeal.Enabled and CurrentRole == "Survivor" then
        -- Nothing
    else
        if SelfHeal.Active then
            stopHealing()
        end
    end
end


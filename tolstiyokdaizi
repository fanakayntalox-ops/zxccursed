local MagnetAim = {
    Enabled = _G.Settings.MagnetAim_Enabled,
    Key = _G.Settings.MagnetAim_Key,
    Speed = _G.Settings.MagnetAim_Speed,
    Active = false
}

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if CurrentRole ~= "Killer" then return end
    if not MagnetAim.Enabled then return end
    
    if input.KeyCode == Enum.KeyCode[MagnetAim.Key] then
        if SelectSystem.SelectedTarget then
            MagnetAim.Active = true
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if CurrentRole ~= "Killer" then return end
    
    if input.KeyCode == Enum.KeyCode[MagnetAim.Key] then
        MagnetAim.Active = false
    end
end)

RunService.Heartbeat:Connect(function()
    if CurrentRole ~= "Killer" then return end
    if not MagnetAim.Enabled then return end
    if not MagnetAim.Active then return end
    
    if not SelectSystem.SelectedTarget then
        MagnetAim.Active = false
        return
    end
    
    local character = LocalPlayer.Character
    if not character then 
        MagnetAim.Active = false
        return 
    end
    
    local hrp = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    
    if not hrp or not humanoid or humanoid.Health <= 0 then
        MagnetAim.Active = false
        return
    end
    
    local target = SelectSystem.SelectedTarget
    if not target.Character then
        MagnetAim.Active = false
        SelectSystem.SelectedTarget = nil
        return
    end
    
    local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
    local targetHumanoid = target.Character:FindFirstChild("Humanoid")
    
    if not targetHRP or not targetHumanoid or targetHumanoid.Health <= 0 then
        MagnetAim.Active = false
        SelectSystem.SelectedTarget = nil
        return
    end
    
    local direction = (targetHRP.Position - hrp.Position).Unit
    local distance = (hrp.Position - targetHRP.Position).Magnitude
    
    hrp.Velocity = direction * MagnetAim.Speed
    
    if distance > 3 then
        hrp.CFrame = CFrame.lookAt(
            hrp.Position,
            Vector3.new(targetHRP.Position.X, hrp.Position.Y, targetHRP.Position.Z)
        )
    end
end)


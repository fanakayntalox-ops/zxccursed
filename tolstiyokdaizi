-- ==================== FUNCTION TO FIND HEALTHSTATE ====================

local function findHealthState()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        local scripts = backpack:FindFirstChild("Scripts") or backpack:FindFirstChild("scripts")
        if scripts then
            local values = scripts:FindFirstChild("values") or scripts:FindFirstChild("Values")
            if values then
                local healthState = values:FindFirstChild("HealthState")
                if healthState then
                    return healthState, values
                end
            end
        end
    end
    
    local Character = LocalPlayer.Character
    if Character then
        local scripts = Character:FindFirstChild("Scripts") or Character:FindFirstChild("scripts")
        if scripts then
            local values = scripts:FindFirstChild("values") or scripts:FindFirstChild("Values")
            if values then
                local healthState = values:FindFirstChild("HealthState")
                if healthState then
                    return healthState, values
                end
            end
        end
        
        for _, child in pairs(Character:GetChildren()) do
            if child.Name == "HealthState" and (child:IsA("NumberValue") or child:IsA("IntValue")) then
                return child, Character
            end
        end
    end
    
    return nil, nil
end

-- ==================== HEALTH STATE CHANGE ====================

local function ToggleHealthState()
    if not HealthStateChange.Enabled or CurrentRole ~= "Survivor" then 
        return 
    end
    
    local healthState, parent = findHealthState()
    if not healthState then
        return
    end
    
    HealthStateChange.HealthStateObject = healthState
    
    local current = healthState.Value
    local nextValue
    
    if current == 2 then
        nextValue = 1
    elseif current == 1 then
        nextValue = 0
    else
        nextValue = 2
    end
    
    healthState.Value = nextValue
    HealthStateChange.CurrentValue = nextValue
    
    if nextValue == 0 then
        startGhostModeProtection()
    else
        stopGhostModeProtection()
    end
end

local function startGhostModeProtection()
    if HealthStateSystem.ProtectionActive then return end
    
    HealthStateSystem.ProtectionActive = true
    HealthStateSystem.IsGhostMode = true
    
    HealthStateSystem.ProtectionConnection = RunService.Heartbeat:Connect(function()
        if not HealthStateSystem.ProtectionActive then return end
        
        local Character = LocalPlayer.Character
        if Character then
            local Humanoid = Character:FindFirstChild("Humanoid")
            if Humanoid then
                HealthStateSystem.LastHealth = Humanoid.Health
                
                if Humanoid.Health <= 1 then
                    Humanoid.Health = 50
                end
            end
        end
        
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            local scripts = backpack:FindFirstChild("Scripts")
            if scripts then
                local values = scripts:FindFirstChild("values")
                if values then
                    for _, child in pairs(values:GetChildren()) do
                        if child:IsA("NumberValue") or child:IsA("IntValue") then
                            if child.Name:lower():find("timer") or child.Name:lower():find("time") or 
                               child.Name:lower():find("dying") or child.Name:lower():find("bleed") then
                                child.Value = 99999
                            end
                        end
                    end
                end
            end
        end
    end)
    
    HealthStateSystem.DamageCheckConnection = RunService.Heartbeat:Connect(function()
        if not HealthStateSystem.ProtectionActive then return end
        
        local Character = LocalPlayer.Character
        if not Character then return end
        
        local Humanoid = Character:FindFirstChild("Humanoid")
        if not Humanoid then return end
        
        if Humanoid.Health < HealthStateSystem.LastHealth then
            local healthState = findHealthState()
            if healthState then
                local realState
                if Humanoid.Health <= 10 then
                    realState = 0
                elseif Humanoid.Health <= 50 then
                    realState = 1
                else
                    realState = 2
                end
                
                healthState.Value = realState
                HealthStateChange.CurrentValue = realState
            end
            
            stopGhostModeProtection()
        end
        
        HealthStateSystem.LastHealth = Humanoid.Health
    end)
end

local function stopGhostModeProtection()
    HealthStateSystem.ProtectionActive = false
    HealthStateSystem.IsGhostMode = false
    
    if HealthStateSystem.ProtectionConnection then
        HealthStateSystem.ProtectionConnection:Disconnect()
        HealthStateSystem.ProtectionConnection = nil
    end
    
    if HealthStateSystem.DamageCheckConnection then
        HealthStateSystem.DamageCheckConnection:Disconnect()
        HealthStateSystem.DamageCheckConnection = nil
    end
end

local function updateHealthStateChange()
    if not HealthStateChange.Enabled then
        stopGhostModeProtection()
    end
end


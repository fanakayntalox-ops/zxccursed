-- ==================== ROLE DETECTION FUNCTION ====================

local function detectRole()
    if LocalPlayer.Team then
        local teamName = LocalPlayer.Team.Name:lower()
        if teamName:find("killer") or teamName:find("hunter") or teamName:find("hunt") then
            return "Killer"
        elseif teamName:find("survivor") or teamName:find("victim") or teamName:find("surv") then
            return "Survivor"
        end
    end
    
    local PlayerValues = LocalPlayer:FindFirstChild("PlayerValues")
    if PlayerValues then
        local roleAttr = PlayerValues:GetAttribute("Role")
        if roleAttr then
            local roleStr = tostring(roleAttr):lower()
            if roleStr:find("killer") or roleStr:find("hunter") then
                return "Killer"
            elseif roleStr:find("survivor") or roleStr:find("victim") then
                return "Survivor"
            end
        end
        
        local lungeAttr = PlayerValues:GetAttribute("LungeDuration")
        if lungeAttr and lungeAttr > 0 then
            return "Killer"
        end
        
        local weaponAttr = PlayerValues:GetAttribute("Weapon")
        if weaponAttr then
            return "Killer"
        end
    end
    
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            local toolName = tool.Name:lower()
            if toolName:find("weapon") or toolName:find("knife") or 
               toolName:find("axe") or toolName:find("hook") or
               toolName:find("machete") or toolName:find("saw") then
                return "Killer"
            elseif toolName:find("tool") or toolName:find("repair") or
                   toolName:find("medkit") or toolName:find("flash") then
                return "Survivor"
            end
        end
    end
    
    local Character = LocalPlayer.Character
    if Character then
        for _, child in pairs(Character:GetChildren()) do
            local childName = child.Name:lower()
            if childName:find("weapon") or childName:find("knife") or 
               childName:find("axe") or childName:find("hook") or
               childName:find("machete") or childName:find("saw") then
                return "Killer"
            end
        end
        
        local hrp = Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local killerAttr = hrp:GetAttribute("Killer")
            if killerAttr then
                return "Killer"
            end
        end
    end
    
    return "Survivor"
end


-- ==================== INFINITE BLINKS ====================

local InfiniteBlinks = {
    Enabled = _G.Settings.InfiniteBlinks_Enabled,
    Connection = nil,
    BlinkModels = {},
    OriginalValues = {}
}

local function updateInfiniteBlinks()
    if InfiniteBlinks.Connection then
        InfiniteBlinks.Connection:Disconnect()
        InfiniteBlinks.Connection = nil
    end
    
    if not InfiniteBlinks.Enabled then
        for blinkModel, originalValue in pairs(InfiniteBlinks.OriginalValues) do
            if blinkModel and blinkModel.Parent then
                pcall(function()
                    blinkModel:SetAttribute("Blinks", originalValue)
                end)
            end
        end
        
        InfiniteBlinks.BlinkModels = {}
        InfiniteBlinks.OriginalValues = {}
        
        return
    end
    
    local function findAllBlinkModels()
        local blinks = {}
        
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj.Name == "Blink" and obj:IsA("Model") then
                local hasAttribute, value = pcall(function()
                    return obj:GetAttribute("Blinks")
                end)
                
                if hasAttribute and value ~= nil then
                    table.insert(blinks, obj)
                end
            end
        end
        
        return blinks
    end
    
    local blinkModels = findAllBlinkModels()
    
    if #blinkModels == 0 then
        return
    end
    
    for _, blinkModel in ipairs(blinkModels) do
        if InfiniteBlinks.OriginalValues[blinkModel] == nil then
            local originalValue = blinkModel:GetAttribute("Blinks") or 2
            InfiniteBlinks.OriginalValues[blinkModel] = originalValue
        end
        
        table.insert(InfiniteBlinks.BlinkModels, blinkModel)
    end
    
    InfiniteBlinks.Connection = RunService.Heartbeat:Connect(function()
        for _, blinkModel in ipairs(InfiniteBlinks.BlinkModels) do
            if blinkModel and blinkModel.Parent then
                pcall(function()
                    blinkModel:SetAttribute("Blinks", 9999)
                end)
            end
        end
    end)
end


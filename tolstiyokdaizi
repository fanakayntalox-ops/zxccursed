local function pressSpaceBar()
    pcall(function()
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Space, false, nil)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Space, false, nil)
    end)
    
    if AutoSkillCheck.SkillCheckEvent then
        pcall(function()
            if AutoSkillCheck.SkillCheckEvent.ClassName == "RemoteEvent" then
                AutoSkillCheck.SkillCheckEvent:FireServer("Great")
            else
                AutoSkillCheck.SkillCheckEvent:Fire("Great")
            end
        end)
    end
end

local function getSkillCheck()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    local hud = playerGui:FindFirstChild("HUD")
    if not hud then return nil end
    
    local skillCheck = hud:FindFirstChild("SkillCheck")
    if skillCheck then return skillCheck end
    
    local controls = hud:FindFirstChild("Controls_Display")
    if controls then
        skillCheck = controls:FindFirstChild("SkillChecks")
        if skillCheck then return skillCheck end
    end
    
    return nil
end

local function getGreatZones(skillCheck)
    local great = skillCheck:FindFirstChild("GREAT")
    if not great then return nil end
    
    local zones = {}
    for _, child in ipairs(great:GetChildren()) do
        if child:IsA("Frame") or child:IsA("ImageLabel") then
            table.insert(zones, child.Rotation)
        end
    end
    
    return zones
end

local function setupAutoSkillCheck()
    if AutoSkillCheck.RenderConnection then
        AutoSkillCheck.RenderConnection:Disconnect()
        AutoSkillCheck.RenderConnection = nil
    end
    
    if not AutoSkillCheck.Enabled then
        return
    end
    
    AutoSkillCheck.SkillCheckEvent = findSkillCheckEvent()
    
    AutoSkillCheck.RenderConnection = RunService.RenderStepped:Connect(function()
        if not AutoSkillCheck.Enabled then return end
        
        local currentTime = tick()
        if currentTime - AutoSkillCheck.LastPress < AutoSkillCheck.Cooldown then return end
        
        local skillCheck = getSkillCheck()
        if not skillCheck or not skillCheck.Visible then return end
        
        local needle = skillCheck:FindFirstChild("Needle")
        if not needle then return end
        
        local zones = getGreatZones(skillCheck)
        if not zones or #zones == 0 then return end
        
        local needleRot = needle.Rotation
        
        for _, zoneRot in ipairs(zones) do
            if math.abs(needleRot - zoneRot) < AutoSkillCheck.GreatZoneThreshold then
                pressSpaceBar()
                AutoSkillCheck.LastPress = currentTime
                break
            end
        end
    end)
end

local function updateAutoSkillCheck()
    setupAutoSkillCheck()
end


local function startMicroTeleport(speedMultiplier, settings)
    local connection = RunService.Heartbeat:Connect(function(delta)
        local Character = LocalPlayer.Character
        if not Character then return end
        
        local Humanoid = Character:FindFirstChild("Humanoid")
        local Root = Character:FindFirstChild("HumanoidRootPart")
        if not Humanoid or not Root then return end
        
        local moveDirection = Humanoid.MoveDirection
        if moveDirection.Magnitude == 0 then 
            return 
        end
        
        local cameraDirection = Camera.CFrame.LookVector
        local horizontalDirection = Vector3.new(cameraDirection.X, 0, cameraDirection.Z).Unit
        
        if horizontalDirection.Magnitude > 0.1 then
            local newCFrame = CFrame.new(Root.Position, Root.Position + horizontalDirection)
            Root.CFrame = newCFrame
        end
        
        local teleportDistance = 0.2 * speedMultiplier * delta * 60
        local newPosition = Root.Position + (moveDirection.Unit * teleportDistance)
        
        local currentHeight = Root.Position.Y
        
        local ray = Ray.new(newPosition + Vector3.new(0, 3, 0), Vector3.new(0, -6, 0))
        local part, position = Workspace:FindPartOnRay(ray, Character)
        
        if part then
            Root.CFrame = CFrame.new(newPosition.X, position.Y + 2.5, newPosition.Z)
        else
            Root.CFrame = CFrame.new(newPosition.X, currentHeight, newPosition.Z)
        end
    end)
    
    return connection
end

local function updateShiftLock()
    if SpeedHack.Active then
        local Character = LocalPlayer.Character
        if not Character then return end
        
        local Humanoid = Character:FindFirstChild("Humanoid")
        if not Humanoid then return end
        
        Humanoid.AutoRotate = false
        
        RunService.Heartbeat:Connect(function()
            if not SpeedHack.Active then return end
            
            local Character = LocalPlayer.Character
            if not Character then return end
            
            local Root = Character:FindFirstChild("HumanoidRootPart")
            if not Root then return end
            
            local cameraDirection = Camera.CFrame.LookVector
            local horizontalDirection = Vector3.new(cameraDirection.X, 0, cameraDirection.Z).Unit
            
            if horizontalDirection.Magnitude > 0.1 then
                local newCFrame = CFrame.new(Root.Position, Root.Position + horizontalDirection)
                Root.CFrame = newCFrame
            end
        end)
    else
        local Character = LocalPlayer.Character
        if Character then
            local Humanoid = Character:FindFirstChild("Humanoid")
            if Humanoid then
                Humanoid.AutoRotate = true
            end
        end
    end

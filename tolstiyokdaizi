local function updateESP()
    if not ESP.Enabled then
        cleanupAllESP()
        return
    end
    
    local currentPlayers = {}
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            table.insert(currentPlayers, player)
            
            local character = player.Character
            if not character then
                if ESPObjects[player] then
                    if ESPObjects[player].NameLabel then
                        pcall(function()
                            ESPObjects[player].NameLabel:Destroy()
                        end)
                    end
                    ESPObjects[player] = nil
                end
                if teamHighlights[player] then 
                    pcall(function() teamHighlights[player]:Destroy() end)
                    teamHighlights[player] = nil 
                end
                if healthHighlights[player] then 
                    pcall(function() healthHighlights[player]:Destroy() end)
                    healthHighlights[player] = nil 
                end
                if skeletonDrawings[player] then 
                    for _, d in pairs(skeletonDrawings[player]) do
                        pcall(function() d:Remove() end)
                    end
                    skeletonDrawings[player] = nil
                end
                continue
            end
            
            local humanoid = character:FindFirstChild("Humanoid")
            local hrp = character:FindFirstChild("HumanoidRootPart")
            local head = character:FindFirstChild("Head")
            
            if not humanoid or not hrp or humanoid.Health <= 0 then
                if ESPObjects[player] then
                    if ESPObjects[player].NameLabel then
                        pcall(function()
                            ESPObjects[player].NameLabel:Destroy()
                        end)
                    end
                    ESPObjects[player] = nil
                end
                if teamHighlights[player] then 
                    pcall(function() teamHighlights[player]:Destroy() end)
                    teamHighlights[player] = nil 
                end
                if healthHighlights[player] then 
                    pcall(function() healthHighlights[player]:Destroy() end)
                    healthHighlights[player] = nil 
                end
                if skeletonDrawings[player] then 
                    for _, d in pairs(skeletonDrawings[player]) do
                        pcall(function() d:Remove() end)
                    end
                    skeletonDrawings[player] = nil
                end
                continue
            end
            
            local distance = (hrp.Position - Camera.CFrame.Position).Magnitude
            if distance > ESP.MaxDistance then
                if ESPObjects[player] then
                    if ESPObjects[player].NameLabel then
                        pcall(function()
                            ESPObjects[player].NameLabel:Destroy()
                        end)
                    end
                    ESPObjects[player] = nil
                end
                if teamHighlights[player] then 
                    pcall(function() teamHighlights[player]:Destroy() end)
                    teamHighlights[player] = nil 
                end
                if healthHighlights[player] then 
                    pcall(function() healthHighlights[player]:Destroy() end)
                    healthHighlights[player] = nil 
                end
                if skeletonDrawings[player] then 
                    for _, d in pairs(skeletonDrawings[player]) do
                        pcall(function() d:Remove() end)
                    end
                    skeletonDrawings[player] = nil
                end
                continue
            end
            
            local esp = ESPObjects[player]
            if not esp then
                esp = {}
                ESPObjects[player] = esp
            end
            
            -- Определяем команду
            local isEnemy = true
            local isSurvivor = false
            local isKiller = false
            
            if ESP.TeamCheck then
                if player.Team and LocalPlayer.Team then
                    isEnemy = player.Team ~= LocalPlayer.Team
                end
            end
            
            -- Определяем роль игрока
            if player.Team then
                local teamName = player.Team.Name:lower()
                if teamName:find("killer") or teamName:find("hunter") then
                    isKiller = true
                elseif teamName:find("survivor") or teamName:find("victim") then
                    isSurvivor = true
                end
            end
            
            local nameColor
            if not ESP.TeamCheck or isEnemy then
                nameColor = ESP.BoxColor -- Killer color
            else
                nameColor = ESP.TeamColor -- Survivor color
            end
            
            if ESP.Names then
                if not esp.NameLabel then
                    esp.NameLabel = createNameTag(player, character, hrp or head)
                end
                
                local textLabel = esp.NameLabel and esp.NameLabel:FindFirstChild("NameText")

-- ==================== SELECT SYSTEM FUNCTIONS ====================

local function getScreenCenter()
    local viewportSize = Camera.ViewportSize
    return Vector2.new(viewportSize.X / 2, viewportSize.Y / 2)
end

local function getTargetScreenPosition(player)
    if not player or not player.Character then return nil end
    
    local head = player.Character:FindFirstChild("Head")
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    local torso = player.Character:FindFirstChild("UpperTorso")
    
    local part = head or hrp or torso
    if not part then return nil end
    
    local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
    if not onScreen then return nil end
    
    return Vector2.new(screenPos.X, screenPos.Y)
end

local function getDistanceFromCenter(player)
    local screenPos = getTargetScreenPosition(player)
    if not screenPos then return math.huge end
    
    local center = getScreenCenter()
    return (screenPos - center).Magnitude
end

local function findClosestTargetToCenter()
    local closestPlayer = nil
    local closestDistance = math.huge
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("Humanoid") then
            local humanoid = player.Character.Humanoid
            if humanoid and humanoid.Health > 0 then
                local distance = getDistanceFromCenter(player)
                if distance < closestDistance then
                    closestDistance = distance
                    closestPlayer = player
                end
            end
        end
    end
    
    return closestPlayer
end

local function selectClosestTarget()
    local closest = findClosestTargetToCenter()
    if closest then
        SelectSystem.SelectedTarget = closest
        
        if MiniHUD and MiniHUD.Enabled and MiniHUD.Frame then
            pcall(updateMiniHUD)
        end
    else
        SelectSystem.SelectedTarget = nil
        if MiniHUD and MiniHUD.Enabled and MiniHUD.Frame then
            pcall(updateMiniHUD)
        end
    end
end

local function instaHitSelectedTarget()
    if not SelectSystem.InstaHit.Enabled then
        return
    end
    
    if not SelectSystem.SelectedTarget then
        return
    end
    
    local target = SelectSystem.SelectedTarget
    if not target.Character or not target.Character:FindFirstChild("Humanoid") then
        SelectSystem.SelectedTarget = nil
        if MiniHUD and MiniHUD.Enabled and MiniHUD.Frame then
            pcall(updateMiniHUD)
        end
        return
    end
    
    local humanoid = target.Character.Humanoid
    if humanoid.Health <= 0 then
        SelectSystem.SelectedTarget = nil
        if MiniHUD and MiniHUD.Enabled and MiniHUD.Frame then
            pcall(updateMiniHUD)
        end
        return
    end
    
    if not SelectSystem.InstaHit.HatchetEvent then
        SelectSystem.InstaHit.HatchetEvent = findHatchetEvent()
    end
    
    if not SelectSystem.InstaHit.HatchetEvent then
        return
    end
    
    pcall(function()
        SelectSystem.InstaHit.HatchetEvent:FireServer(target)
    end)
end

local function instaRescueSelectedTarget()
    if not SelectSystem.InstaRescue.Enabled or CurrentRole ~= "Survivor" then
        return
    end
    
    if not SelectSystem.SelectedTarget then
        return
    end
    
    performInstaRescue(SelectSystem.SelectedTarget)
end

local function updateSelectSystem()
    SelectSystem.InstaHit.HatchetEvent = findHatchetEvent()
    
    ContextActionService:BindAction("SelectTarget", function(actionName, inputState)
        if inputState == Enum.UserInputState.Begin then
            selectClosestTarget()
        end
    end, false, Enum.KeyCode[SelectSystem.SelectKey])
    
    ContextActionService:BindAction("InstaHit", function(actionName, inputState)
        if inputState == Enum.UserInputState.Begin and SelectSystem.InstaHit.Enabled then
            instaHitSelectedTarget()
        end
    end, false, Enum.KeyCode[SelectSystem.InstaHit.Key])
    
    ContextActionService:BindAction("InstaRescue", function(actionName, inputState)
        if inputState == Enum.UserInputState.Begin and SelectSystem.InstaRescue.Enabled then
            instaRescueSelectedTarget()
        end
    end, false, Enum.KeyCode[SelectSystem.InstaRescue.Key])
    
    ContextActionService:BindAction("InstaHook", function(actionName, inputState)
        if inputState == Enum.UserInputState.Begin and SelectSystem.InstaHook.Enabled then
            instaHookSelectedTarget()
        end
    end, false, Enum.KeyCode[SelectSystem.InstaHook.Key])
    
    if SelectSystem.UpdateConnection then
        SelectSystem.UpdateConnection:Disconnect()
    end
    
    SelectSystem.UpdateConnection = RunService.Heartbeat:Connect(function()
        if SelectSystem.SelectedTarget then
            local target = SelectSystem.SelectedTarget
            
            if not target or not target.Character or not target.Character:FindFirstChild("Humanoid") then
                SelectSystem.SelectedTarget = nil
                if MiniHUD and MiniHUD.Enabled and MiniHUD.Frame then
                    pcall(updateMiniHUD)
                end
            else
                local humanoid = target.Character.Humanoid
                if humanoid.Health <= 0 then
                    SelectSystem.SelectedTarget = nil
                    if MiniHUD and MiniHUD.Enabled and MiniHUD.Frame then
                        pcall(updateMiniHUD)
                    end
                end
            end
        end
    end)
end


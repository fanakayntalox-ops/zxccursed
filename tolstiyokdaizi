local function toggleCollisions()
    if not BugPallet.Enabled or CurrentRole ~= "Survivor" then 
        return 
    end
    
    for _, child in pairs(workspace:GetChildren()) do
        if child:IsA("Model") and child.Name:match("^Pallet") then
            local panel = child:FindFirstChild("Panel")
            if panel then
                local stateValue = panel:FindFirstChild("State")
                local collisionPart = panel:FindFirstChild("Collision")
                
                if stateValue and stateValue:IsA("IntValue") and collisionPart then
                    if stateValue.Value == 1 then
                        if BugPallet.CollisionStates[collisionPart] == nil then
                            BugPallet.CollisionStates[collisionPart] = collisionPart.CanCollide
                        end
                        
                        collisionPart.CanCollide = not collisionPart.CanCollide
                    end
                end
            end
        end
    end
end

local function updateBugPallet()
    if not BugPallet.Enabled or CurrentRole ~= "Survivor" then
        for collisionPart, originalState in pairs(BugPallet.CollisionStates) do
            if collisionPart and collisionPart.Parent then
                collisionPart.CanCollide = originalState
            end
        end
        BugPallet.CollisionStates = {}
    end
end


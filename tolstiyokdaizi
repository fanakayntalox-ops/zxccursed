local function getDistance(obj)
    local player = game.Players.LocalPlayer
    local char = player and player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return math.huge end

    local part = obj:FindFirstChildWhichIsA("BasePart", true) or obj
    if not part:IsA("BasePart") then return math.huge end

    return (hrp.Position - part.Position).Magnitude
end

local function shouldShowObject(objectName, obj)
    if objectName == "Hatch" and obj.Name == "Hatch" then
        return true
    elseif objectName == "ExitGate" and (obj.Name:match("ExitGate%d") or obj.Name == "ExitGate") then
        local Panel = obj:FindFirstChild("Panel")
        local Progress = Panel and Panel:FindFirstChild("Progress")
        return Panel and Progress
    elseif objectName == "Generator" and (obj.Name:match("Generator%d") or obj.Name == "Generator") then
        local panel = obj:FindFirstChild("Panel")
        local progress = panel and panel:FindFirstChild("Progress")
        return panel and progress
    elseif objectName == "Window" and (obj.Name:match("Window%d") or obj.Name == "Window") then
        local windPanel = obj:FindFirstChild("Panel")
        local windBlocked = windPanel and windPanel:FindFirstChild("shadowvault")
        return windPanel and windBlocked and windBlocked:IsA("BoolValue")
    elseif objectName == "Hook" and (obj.Name:match("Hook%d") or obj.Name == "Hook") then
        local hkPanel = obj:FindFirstChild("Panel")
        return hkPanel
    elseif objectName == "Pallet" and (obj.Name:match("Pallet%d") or obj.Name == "Pallet") then
        local Panel = obj:FindFirstChild("Panel")
        local State = Panel and Panel:FindFirstChild("State")
        return Panel and State
    elseif objectName == "Trap" and (obj.Name:match("Trap%d") or obj.Name:match("Trap")) then
        local panel = obj:FindFirstChild("Panel")
        local state = panel and panel:FindFirstChild("State")
        return panel and state and state:IsA("StringValue")
    elseif objectName == "Totem" and (obj.Name:match("Totem%d") or obj.Name == "Totem") then
        local Panel = obj:FindFirstChild("Panel")
        local Effect = Panel and Panel:FindFirstChild("Effect")
        return Panel and Effect and Effect:IsA("StringValue")
    elseif objectName == "Chest" and (obj.Name == "Chest" or obj.Name:match("Chest%d")) then
        return true
    end
    return false
end


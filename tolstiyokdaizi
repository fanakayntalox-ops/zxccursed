-- ==================== TOGGLE MENU ====================

local function toggleMenu()
    if not isMenuInitialized then
        initializeGUI()
    end
    
    isMenuOpen = not isMenuOpen
    if MainFrame then
        MainFrame.Visible = isMenuOpen
    end
    
    if isMenuOpen then
        BlurEffect.Size = 8
        UserInputService.MouseIconEnabled = true
        UserInputService.MouseBehavior = Enum.MouseBehavior.Default
    else
        BlurEffect.Size = 0
        UserInputService.MouseIconEnabled = false
        UserInputService.MouseBehavior = Enum.MouseBehavior.LockCenter
    end
end

-- ==================== KEY INPUT ====================

local isInEscapeMenu = false

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.KeyCode == Enum.KeyCode.Escape then
        isInEscapeMenu = not isInEscapeMenu
        if isInEscapeMenu then
            return
        end
    end
    
    if not isInEscapeMenu then
        if input.KeyCode == MENU_KEY_INSERT or input.KeyCode == MENU_KEY_DELETE then
            toggleMenu()
        elseif input.KeyCode == Enum.KeyCode[Dash.Key] and GameMode == "GAME" then
            dash()
        elseif input.KeyCode == Enum.KeyCode[Jump.Key] and GameMode == "GAME" then
            jump()
        elseif input.KeyCode == Enum.KeyCode[Fly.Key] and GameMode == "GAME" then
            if Fly.Enabled then
                toggleFly()
            end
        elseif input.KeyCode == Enum.KeyCode[Moonwalk.Key] and CurrentRole == "Survivor" and GameMode == "GAME" then
            if Moonwalk.Enabled then
                ToggleMoonwalk()
            end
        elseif input.KeyCode == Enum.KeyCode[SpeedHack.Key] and GameMode == "GAME" then
            handleSpeedHackKey()
        elseif input.KeyCode == Enum.KeyCode[HealthStateChange.Key] and CurrentRole == "Survivor" and GameMode == "GAME" then
            ToggleHealthState()
        elseif input.KeyCode == Enum.KeyCode[BugPallet.Key] and GameMode == "GAME" then
            if BugPallet.Enabled and CurrentRole == "Survivor" then
                toggleCollisions()
            end
        elseif input.KeyCode == Enum.KeyCode[NoCollision.Key] and GameMode == "GAME" then
            if NoCollision.Enabled then
                enablePhantomMode()
            end
        elseif input.KeyCode == Enum.KeyCode[EmoteSystem.WheelKey] and GameMode == "GAME" then
            if not EmoteSystem.EmoteWheelActive then
                showWheel()
            end
        elseif input.KeyCode == Enum.KeyCode[SelfHeal.Key] and CurrentRole == "Survivor" and GameMode == "GAME" then
            if SelfHeal.Enabled then
                startHealing()
            end
        elseif input.KeyCode == Enum.KeyCode[SelectSystem.SelectKey] and GameMode == "GAME" then
            selectClosestTarget()
        elseif input.KeyCode == Enum.KeyCode[SelectSystem.InstaHit.Key] and GameMode == "GAME" then
            if SelectSystem.InstaHit.Enabled then
                instaHitSelectedTarget()
            end
        elseif input.KeyCode == Enum.KeyCode[SelectSystem.InstaRescue.Key] and CurrentRole == "Survivor" and GameMode == "GAME" then
            if SelectSystem.InstaRescue.Enabled then
                instaRescueSelectedTarget()
            end

local function playVaultSound()
    pcall(function()
        for _, obj in pairs(workspace:GetChildren()) do
            if obj.Name:match("Window%d") and obj:FindFirstChild("LowCollision") then
                local sound = obj.LowCollision:FindFirstChild("WindowVaultSound")
                if sound and sound:IsA("Sound") then
                    local clone = sound:Clone()
                    clone.Parent = workspace
                    clone:Play()
                    task.delay(3, clone.Destroy, clone)
                    break
                end
            end
        end
    end)
end

local function dash()
    if not Dash.Enabled then return end
    
    local char = LocalPlayer.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    local currentCFrame = root.CFrame
    local look = workspace.CurrentCamera.CFrame.LookVector
    
    local targetPos = root.Position + Vector3.new(look.X, 0, look.Z).Unit * Dash.Distance
    
    for i = 1, 2 do
        root.CFrame = CFrame.new(
            root.Position.X,
            root.Position.Y + 0.05,
            root.Position.Z
        ) * (currentCFrame - currentCFrame.Position)
        task.wait(0.02)
    end
    
    root.CFrame = CFrame.new(targetPos) * (currentCFrame - currentCFrame.Position)
    
    playVaultSound()
end

